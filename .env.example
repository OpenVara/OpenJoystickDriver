# OpenJoystickDriver - Publisher signing credentials
#
# This file is for PUBLISHER only (person releasing official builds).
# Regular contributors and developers do NOT need this - use scripts/sign-dev.sh
# for local development, which uses ad-hoc signing and requires no account.
#
# Setup:
#   cp .env.example .env
#   Fill in your values below.
#   .env is already in .gitignore - never commit it.
#
# Then run: ./scripts/build-release.sh

# ─── 1. CODESIGN_IDENTITY ─────────────────────────────────────────────────────
# Your Developer ID Application certificate identity string.
#
# How to get it:
#   a. Go to <https://developer.apple.com> -> Certificates, IDs & Profiles -> Certificates
#   b. Click (+) -> choose "Developer ID Application" -> follow CSR steps:
#        Keychain Access -> Certificate Assistant -> Request Certificate from CA
#        Save to disk, upload to Apple, download .cer, double-click to install.
#   c. Find exact identity string by running in Terminal:
#        security find-identity -v -p codesigning | grep "Developer ID"
#      Example output:
#        1) A1B2C3... "Developer ID Application: Jane Doe (ABC1234XYZ)"
#   d. Copy full quoted string below.
CODESIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# ─── 2. APPLE_TEAM_ID ─────────────────────────────────────────────────────────
# Your 10-character Apple Developer Team ID.
#
# How to get it:
#   developer.apple.com -> Account -> Membership Details -> Team ID
#   Example: ABC1234XYZ
APPLE_TEAM_ID="XXXXXXXXXX"

# ─── 3. APPLE_ID ──────────────────────────────────────────────────────────────
# Apple Account email address associated with your Developer account.
APPLE_ID="you@example.com"

# ─── 4. APPLE_ID_PASSWORD ─────────────────────────────────────────────────────
# App-specific password for xcrun notarytool.
# This is NOT your Apple Account password - it is generated token.
#
# How to get it:
#   a. Go to <https://account.apple.com> -> Sign in
#   b. "Sign-in and Security" section -> "App-Specific Passwords" -> click (+)
#   c. Name it "OpenJoystickDriver notarytool" (or any label you'll recognise)
#   d. Copy generated password - format: xxxx-xxxx-xxxx-xxxx
APPLE_ID_PASSWORD="xxxx-xxxx-xxxx-xxxx"
