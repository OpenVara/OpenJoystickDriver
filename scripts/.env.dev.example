# Development signing (dext builds, local testing)
# Copy to scripts/.env.dev and fill in your values.

# Apple Development certificate (for dext + dev builds)
CODESIGN_IDENTITY="Apple Development: Your Name (TEAMID)"

# Apple Developer Team ID
DEVELOPMENT_TEAM="ABCDEF1234"

# Provisioning profile with DriverKit entitlements
PROVISIONING_PROFILE_SPECIFIER="OpenJoystickDevice"
