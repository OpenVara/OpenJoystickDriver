# Release signing (distribution, notarization)
# Copy to scripts/.env.release and fill in your values.

# Developer ID certificate (for distribution outside App Store)
CODESIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Apple Developer Team ID
DEVELOPMENT_TEAM="ABCDEF1234"

# Dext provisioning profile (Developer ID)
PROVISIONING_PROFILE_SPECIFIER="OpenJoystickDriver VirtualHIDDevice DevID"

# App and daemon provisioning profiles (Developer ID)
GUI_PROVISIONING_PROFILE="$HOME/Library/MobileDevice/Provisioning Profiles/OpenJoystickDriver App DevID.provisionprofile"
DAEMON_PROVISIONING_PROFILE="$HOME/Library/MobileDevice/Provisioning Profiles/OpenJoystickDriverDaemon DevID.provisionprofile"

# Notarization credentials
NOTARIZE_APPLE_ID=""           # your Apple ID email
NOTARIZE_PASSWORD=""           # app-specific password (xxxx-xxxx-xxxx-xxxx)
