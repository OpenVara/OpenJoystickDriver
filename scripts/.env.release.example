# Release signing (distribution, notarization)
# Copy to scripts/.env.release and fill in your values.

# Developer ID certificate (for distribution outside App Store)
CODESIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Apple Developer Team ID
DEVELOPMENT_TEAM="ABCDEF1234"

# Notarization credentials (app-specific password)
NOTARIZE_APPLE_ID="you@example.com"
NOTARIZE_PASSWORD="@keychain:AC_PASSWORD"
NOTARIZE_TEAM_ID="ABCDEF1234"
