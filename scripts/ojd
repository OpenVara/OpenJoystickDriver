#!/usr/bin/env bash
# OpenJoystickDriver developer entrypoint.
#
# Goal: one command surface for common tasks, with self-describing failures.
#
# Use this instead of invoking individual scripts directly.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

usage() {
  cat <<'USAGE'
OpenJoystickDriver — dev helper

Usage:
  ./scripts/ojd <command> [args]

Commands:
  rebuild dev                 Full rebuild (app + dext), installs to /Applications
  rebuild release             Same as above, but uses release signing + notarization
  rebuild-fast dev            Fast rebuild (app only; preserves installed dext)

  build dev                   Build + sign app bundle into `.build/` (no dext)
  build release               Build + sign app bundle for release (no dext)
  build dext                  Build DriverKit `.dext` and embed into `.build/` app
  bump-version <version>      Update release version references

  signing install-profiles    Copy profiles from ~/Documents/Profiles into MobileDevice
  signing configure            Generate .env.dev + .env.release from Keychain + profiles
  signing doctor               Diagnose common cert/profile mismatch errors (safe output)
  signing audit [paths...]     Audit profiles without leaking identifiers
  signing cert-info <cer>      Show safe-ish .cer info (Team ID = Subject OU)
  signing profile-info <pp>    Show safe-ish profile embedded cert info
  signing import-embedded <pp> Import embedded cert from a profile into Keychain
  signing ci-release-setup     Import GitHub Actions release secrets (CI only)
  signing export-github-secrets
                               Write/import GitHub Actions release secrets

  diagnose dext               Run dext diagnostics (activation, codesign, IORegistry, daemon connection)
  diagnose sdl3 [--seconds N] Run SDL3 probe against the virtual device
  diagnose sdl3-gamecontroller [--seconds N]
                              Run SDL3 through GameController/MFI and test rumble
  diagnose sdl3-hidapi-x360 [--seconds N]
                              Run SDL3 through Xbox 360 HIDAPI and test rumble
  diagnose gamecontroller     Run GameController.framework probe
  diagnose catalina [app]     Check a macOS 10.15 test app bundle
  diagnose backends           Run current backend acceptance loop
  repair stale-dext           Kill stale DriverKit process copies after upgrade
  repair swiftpm-module-cache Clear SwiftPM module caches under `.build/` (fixes toolchain/target mismatches)
  validate profiles           Validate bundled controller profiles
  launch sdl-gamecontroller <app>
                              Launch an SDL app through GameController/MFI rumble route
  rtk install-filters         Create/update project-local RTK filters without duplicates

  notarize submit             Submit + poll + staple (release only)
  notarize status [id]        Show notarization status (release only)
  notarize log <id>           Fetch notarization log (release only)
  notarize history            List notarization history (release only)
  notarize store-credentials  Store notarytool credentials in Keychain
  package release             Build, notarize, staple, and package a release DMG

  lint                        Run SwiftLint (requires swiftlint)

Examples:
  ./scripts/ojd signing install-profiles
  ./scripts/ojd signing configure
  ./scripts/ojd rebuild-fast dev
  ./scripts/ojd bump-version 0.1.0-rc.2

Notes:
  - Most commands expect the app to be installed to /Applications.
  - DriverKit upgrades can require a reboot; use rebuild-fast while streaming.
USAGE
}

die() { echo "ERROR: $*" >&2; exit 2; }

cmd="${1:-}"
shift || true

case "$cmd" in
  ""|-h|--help|help)
    usage
    exit 0
    ;;

  build)
    sub="${1:-}"; shift || true
    case "$sub" in
      dev)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-build.sh" build dev
        ;;
      dext)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-build.sh" build dext
        ;;
      release)
        exec env OJD_ENV=release /usr/bin/env bash "$SCRIPT_DIR/ojd-build.sh" build release
        ;;
      *)
        die "Unknown: build $sub (expected: dev | dext | release)"
        ;;
    esac
    ;;

  rebuild)
    sub="${1:-}"; shift || true
    case "$sub" in
      dev)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-build.sh" rebuild dev
        ;;
      release)
        exec env OJD_ENV=release /usr/bin/env bash "$SCRIPT_DIR/ojd-build.sh" rebuild release
        ;;
      *)
        die "Unknown: rebuild $sub (expected: dev | release)"
        ;;
    esac
    ;;

  rebuild-fast)
    sub="${1:-}"; shift || true
    case "$sub" in
      dev)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-build.sh" rebuild-fast dev
        ;;
      *)
        die "Unknown: rebuild-fast $sub (expected: dev)"
        ;;
    esac
    ;;

  bump-version)
    exec /usr/bin/env bash "$SCRIPT_DIR/bump-version.sh" "$@"
    ;;

  signing)
    sub="${1:-}"; shift || true
    case "$sub" in
      ""|-h|--help|help)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-signing.sh" help
        ;;
      install-profiles)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-signing.sh" install-profiles "${1:-}"
        ;;
      configure)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-signing.sh" configure
        ;;
      doctor)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-signing.sh" doctor
        ;;
      audit)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-signing.sh" audit "$@"
        ;;
      cert-info)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-signing.sh" cert-info "$@"
        ;;
      profile-info)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-signing.sh" profile-info "$@"
        ;;
      import-embedded)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-signing.sh" import-embedded "$@"
        ;;
      ci-release-setup)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-signing.sh" ci-release-setup "$@"
        ;;
      export-github-secrets)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-github-secrets.sh" "$@"
        ;;
      *)
        die "Unknown: signing $sub (expected: install-profiles | configure | doctor | audit | cert-info | profile-info | import-embedded | ci-release-setup | export-github-secrets)"
        ;;
    esac
    ;;

  diagnose)
    sub="${1:-}"; shift || true
    case "$sub" in
      dext)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-diagnose.sh" dext
        ;;
      sdl3)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-diagnose.sh" sdl3 "$@"
        ;;
      sdl3-gamecontroller)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-diagnose.sh" sdl3-gamecontroller "$@"
        ;;
      sdl3-hidapi-x360)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-diagnose.sh" sdl3-hidapi-x360 "$@"
        ;;
      gamecontroller)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-diagnose.sh" gamecontroller "$@"
        ;;
      catalina)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-catalina-smoke.sh" "$@"
        ;;
      backends)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-diagnose.sh" backends "$@"
        ;;
      *)
        die "Unknown: diagnose $sub (expected: dext | sdl3 | sdl3-gamecontroller | sdl3-hidapi-x360 | gamecontroller | catalina | backends)"
        ;;
    esac
    ;;

  validate)
    sub="${1:-}"; shift || true
    case "$sub" in
      profiles)
        exec /usr/bin/env python3 "$SCRIPT_DIR/ojd-validate-profiles.py"
        ;;
      *)
        die "Unknown: validate $sub (expected: profiles)"
        ;;
    esac
    ;;

  repair)
    sub="${1:-}"; shift || true
    case "$sub" in
      stale-dext)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-repair-stale-dext.sh" "$@"
        ;;
      swiftpm-module-cache)
        (
          cd "$PROJECT_DIR"
          if [[ ! -d ".build" ]]; then
            echo "No .build directory; nothing to clean."
            exit 0
          fi

          removed=0
          while IFS= read -r -d '' dir; do
            rm -rf "$dir"
            removed=$((removed + 1))
          done < <(find ".build" -type d -name 'ModuleCache' -print0 2>/dev/null || true)

          echo "Removed $removed SwiftPM module cache directories."
        )
        ;;
      *)
        die "Unknown: repair $sub (expected: stale-dext | swiftpm-module-cache)"
        ;;
    esac
    ;;

  launch)
    sub="${1:-}"; shift || true
    case "$sub" in
      sdl-gamecontroller)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-launch-sdl-gamecontroller.sh" "$@"
        ;;
      *)
        die "Unknown: launch $sub (expected: sdl-gamecontroller)"
        ;;
    esac
    ;;

  lint)
    exec /usr/bin/env bash "$SCRIPT_DIR/ojd-build.sh" lint
    ;;

  rtk)
    sub="${1:-}"; shift || true
    case "$sub" in
      install-filters)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-rtk-filters.sh" install-filters
        ;;
      ""|-h|--help|help)
        exec /usr/bin/env bash "$SCRIPT_DIR/ojd-rtk-filters.sh" help
        ;;
      *)
        die "Unknown: rtk $sub (expected: install-filters)"
        ;;
    esac
    ;;

  notarize)
    sub="${1:-}"; shift || true
    case "$sub" in
      submit|"")
        exec env OJD_ENV=release /usr/bin/env bash "$SCRIPT_DIR/ojd-notarize.sh" submit "$@"
        ;;
      help|-h|--help)
        exec env OJD_ENV=release /usr/bin/env bash "$SCRIPT_DIR/ojd-notarize.sh" help
        ;;
      status)
        exec env OJD_ENV=release /usr/bin/env bash "$SCRIPT_DIR/ojd-notarize.sh" status "$@"
        ;;
      history)
        exec env OJD_ENV=release /usr/bin/env bash "$SCRIPT_DIR/ojd-notarize.sh" history "$@"
        ;;
      log)
        exec env OJD_ENV=release /usr/bin/env bash "$SCRIPT_DIR/ojd-notarize.sh" log "$@"
        ;;
      store-credentials)
        exec env OJD_ENV=release /usr/bin/env bash "$SCRIPT_DIR/ojd-notarize.sh" store-credentials "$@"
        ;;
      *)
        die "Unknown: notarize $sub (expected: submit | status | history | log | store-credentials)"
        ;;
    esac
    ;;

  package)
    sub="${1:-}"; shift || true
    case "$sub" in
      ""|-h|--help|help)
        exec env OJD_ENV=release /usr/bin/env bash "$SCRIPT_DIR/ojd-package.sh" help
        ;;
      release)
        exec env OJD_ENV=release /usr/bin/env bash "$SCRIPT_DIR/ojd-package.sh" release "$@"
        ;;
      *)
        die "Unknown: package $sub (expected: release)"
        ;;
    esac
    ;;

  *)
    die "Unknown command: $cmd (run: ./scripts/ojd --help)"
    ;;
esac
