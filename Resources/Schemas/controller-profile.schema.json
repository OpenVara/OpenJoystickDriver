{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xsyetopz/OpenJoystickDriver/main/Resources/Schemas/controller-profile.schema.json",
  "title": "OpenJoystickDriver Controller Profile",
  "description": "Describes one controller model: identity, input transport, protocol, mapping, and virtual output metadata. All numeric values are decimal.",
  "type": "object",
  "required": [
    "profile_version",
    "identity",
    "input",
    "protocol",
    "output"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "profile_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "identity": {
      "$ref": "#/$defs/identity"
    },
    "input": {
      "$ref": "#/$defs/input"
    },
    "protocol": {
      "$ref": "#/$defs/protocol"
    },
    "output": {
      "$ref": "#/$defs/output"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "required": [
        "source",
        "hardware_verified"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "local-hardware",
            "linux-xpad.c"
          ]
        },
        "hardware_verified": {
          "type": "boolean"
        }
      }
    },
    "identity": {
      "type": "object",
      "required": [
        "vendor_id",
        "product_id",
        "name",
        "short_name"
      ],
      "additionalProperties": false,
      "properties": {
        "vendor_id": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "product_id": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "short_name": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]+$"
        }
      }
    },
    "input": {
      "type": "object",
      "required": [
        "transport",
        "usb"
      ],
      "additionalProperties": false,
      "properties": {
        "transport": {
          "type": "string",
          "enum": [
            "usb",
            "hid"
          ]
        },
        "usb": {
          "$ref": "#/$defs/usb"
        }
      }
    },
    "usb": {
      "type": "object",
      "required": [
        "class",
        "interface"
      ],
      "additionalProperties": false,
      "properties": {
        "class": {
          "type": "integer",
          "enum": [
            3,
            255
          ]
        },
        "interface": {
          "type": "integer",
          "minimum": 0
        },
        "configuration": {
          "type": "string",
          "enum": [
            "set1BeforeClaim"
          ]
        },
        "post_handshake_settle_ms": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "endpoints": {
          "$ref": "#/$defs/endpoints"
        }
      }
    },
    "endpoints": {
      "type": "object",
      "required": [
        "in",
        "out"
      ],
      "additionalProperties": false,
      "properties": {
        "in": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "out": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        }
      }
    },
    "protocol": {
      "oneOf": [
        {
          "$ref": "https://raw.githubusercontent.com/xsyetopz/OpenJoystickDriver/main/Resources/Schemas/Protocols/gip.schema.json"
        },
        {
          "$ref": "https://raw.githubusercontent.com/xsyetopz/OpenJoystickDriver/main/Resources/Schemas/Protocols/xbox360.schema.json"
        },
        {
          "$ref": "https://raw.githubusercontent.com/xsyetopz/OpenJoystickDriver/main/Resources/Schemas/Protocols/ds4.schema.json"
        },
        {
          "$ref": "https://raw.githubusercontent.com/xsyetopz/OpenJoystickDriver/main/Resources/Schemas/Protocols/generic-hid.schema.json"
        }
      ]
    },
    "output": {
      "type": "object",
      "required": [
        "virtual_profile",
        "preferred_backends"
      ],
      "additionalProperties": false,
      "properties": {
        "virtual_profile": {
          "type": "string",
          "enum": [
            "xboxOneS"
          ]
        },
        "preferred_backends": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "driverKitHID",
              "userSpaceHID",
              "gameControllerVirtual"
            ]
          }
        }
      }
    }
  }
}
