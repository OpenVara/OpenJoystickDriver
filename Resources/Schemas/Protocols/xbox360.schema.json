{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/xsyetopz/OpenJoystickDriver/main/Resources/Schemas/Protocols/xbox360.schema.json",
  "title": "OpenJoystickDriver Xbox 360 Protocol Profile",
  "description": "Protocol-specific metadata for Xbox 360 wired controllers using the vendor-specific USB class 0xFF interface.",
  "type": "object",
  "required": [
    "driver",
    "variant"
  ],
  "additionalProperties": false,
  "properties": {
    "driver": {
      "const": "Xbox360"
    },
    "variant": {
      "type": "string",
      "enum": [
        "xbox360",
        "unknown"
      ]
    },
    "mapping_flags": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "dpadToButtons",
          "triggersToButtons",
          "sticksToNull"
        ]
      },
      "default": []
    }
  }
}
